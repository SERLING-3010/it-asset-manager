generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  TECHNICIAN
  EMPLOYEE
}

enum AssetType {
  COMPUTER
  LAPTOP
  MOBILE
  TABLET
  PRINTER
  NETWORK
  SOFTWARE
  PERIPHERAL
  OTHER
}

enum AssetStatus {
  AVAILABLE
  ASSIGNED
  MAINTENANCE
  REPAIR
  RETIRED
  STOLEN
}

enum MaintenanceType {
  PREVENTIVE
  CORRECTIVE
  UPGRADE
  WARRANTY
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  password      String?
  role          UserRole  @default(EMPLOYEE)
  department    String?
  phone         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  assignedAssets    AssetAssignment[]
  createdMaintenances Maintenance[] @relation("TechnicianMaintenances")
  auditLogs       AuditLog[]
  
  accounts Account[]
  sessions Session[]
}

model Asset {
  id              String      @id @default(cuid())
  name            String
  serialNumber    String      @unique
  type            AssetType
  status          AssetStatus @default(AVAILABLE)
  brand           String
  model           String
  purchaseDate    DateTime
  warrantyEndDate DateTime?
  purchasePrice   Float
  currentValue    Float?
  specifications  String?
  notes           String?
  location        String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  
  assignments     AssetAssignment[]
  maintenances    Maintenance[]
  
  @@index([type])
  @@index([status])
  @@index([serialNumber])
}

model AssetAssignment {
  id          String   @id @default(cuid())
  assetId     String
  userId      String
  assignedAt  DateTime @default(now())
  returnedAt  DateTime?
  condition   String?
  notes       String?
  
  asset       Asset    @relation(fields: [assetId], references: [id])
  user        User     @relation(fields: [userId], references: [id])
  
  @@unique([assetId, assignedAt])
}

model Maintenance {
  id            String         @id @default(cuid())
  assetId       String
  technicianId  String
  type          MaintenanceType
  description   String
  cost          Float
  performedAt   DateTime       @default(now())
  nextMaintenance DateTime?
  warrantyClaim Boolean        @default(false)
  provider      String?
  invoiceNumber String?
  
  asset         Asset          @relation(fields: [assetId], references: [id])
  technician    User           @relation("TechnicianMaintenances", fields: [technicianId], references: [id])
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String
  action    String
  entity    String
  entityId  String?
  details   String?
  timestamp DateTime @default(now())
  
  user      User     @relation(fields: [userId], references: [id])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}